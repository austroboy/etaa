# ============================================================
# ETAA – Enterprise Task Automation Agent
# Copy this file to .env and fill in all values before running.
# ============================================================

# ── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (leave blank to use SQLite for development) ─────
# DATABASE_URL=postgres://user:password@localhost:5432/etaa_db

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── The 3 core operators ─────────────────────────────────────
# Phone numbers with country code, NO '+' prefix, digits only.
# These three are individually authorized everywhere – in DMs to
# the bot AND in every group the bot is in. Only they can grant
# in-group access to additional members.
OPERATOR_1_PHONE=8801700000001
OPERATOR_1_NAME=Zihad Milon
OPERATOR_2_PHONE=8801700000002
OPERATOR_2_NAME=Mohibur Rahman
OPERATOR_3_PHONE=8801700000003
OPERATOR_3_NAME=Shafiqur Rahman

# ── WhatsApp Bridge ───────────────────────────────────────────
# Comma-separated list of the 3 core operator phones. The Node
# bridge uses this to drop DMs from non-operators at the edge
# (groups are always forwarded; Django decides who is allowed
# to issue instructions inside them).
CORE_OPERATOR_PHONES=8801700000001,8801700000002,8801700000003

# Optional: a default group JID used as a fallback target for
# unsolicited bot messages (e.g. periodic inbox monitor updates).
# Replies to a specific instruction always go back to the chat
# the instruction came from – this is just for unsolicited push.
WHATSAPP_GROUP_JID=

WHATSAPP_BRIDGE_URL=http://localhost:3000
WHATSAPP_API_TOKEN=etaa-bridge-secret-token

# ── Company Info ──────────────────────────────────────────────
COMPANY_NAME=Zihad IT

# ── SMTP (Outbound Email) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
COMPANY_EMAIL=your-email@gmail.com

# ── IMAP (Inbound Email Monitoring) ──────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── LLM Providers ─────────────────────────────────────────────
PRIMARY_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Drive (for CV collection) ─────────────────────────
# Paste the full contents of your service account JSON here (single line).
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Canva API (for Job Post image generation) ─────────────────
CANVA_API_KEY=
CANVA_JOB_POST_TEMPLATE_ID=

# ── Git (for code push feature) ───────────────────────────────
GIT_SSH_KEY_PATH=~/.ssh/id_rsa
GIT_PAT=

# ── Output directories ────────────────────────────────────────
OUTPUT_DIR=outputs
CV_TEMP_DIR=temp/cvs
CODE_OUT_DIR=outputs/code

# ── Operational parameters ────────────────────────────────────
CONFIRMATION_TIMEOUT=300
LOG_RETENTION_DAYS=90
LOG_MAX_FILE_SIZE_MB=50

# ── WhatsApp Bridge (Node.js side) ────────────────────────────
WA_BRIDGE_PORT=3000
DJANGO_WEBHOOK_URL=http://localhost:8000/api/messaging/webhook/
